POSTGRES_USER=verein
POSTGRES_PASSWORD=verein_secret
POSTGRES_DB=vereinsbestellung

# Docker-Images aus GitHub Container Registry (Workflow „Docker Images“)
GHCR_IMAGE_PREFIX=ghcr.io/timux/festschmiede
IMAGE_TAG=latest

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173
# Optional: Virenscan für Uploads (Skript erhält Dateipfad, Exit 0 = OK)
# UPLOAD_AV_HOOK=/usr/local/bin/scan-upload.sh

# Multi-Tenant (v2.0) – kanonische Domain-Architektur
# MULTI_TENANT_ENABLED=false
# DEFAULT_TENANT_SLUG=default
# PLATFORM_DOMAIN=localhost
# WWW_SUBDOMAIN=www
# APP_SUBDOMAIN=app
# API_SUBDOMAIN=api
# DOCS_SUBDOMAIN=docs
# STATUS_SUBDOMAIN=status
# PLATFORM_RESERVED_SUBDOMAINS=
# PLATFORM_WWW_DOMAIN=
# PLATFORM_APP_DOMAIN=
# PLATFORM_API_DOMAIN=
# PLATFORM_WILDCARD_DOMAIN=*.localhost
# PLATFORM_ALLOWED_ORIGINS=http://localhost:5173
# ALLOWED_ORIGINS=
# PLATFORM_COOKIE_DOMAIN=
# COOKIE_DOMAIN=
# PLATFORM_SESSION_DOMAIN=
# SESSION_DOMAIN=
# TRUSTED_HOSTS=
# TRUSTED_PROXY_HOPS=1
# TRUSTED_PROXY_IPS=127.0.0.1,::1
# ACME_EMAIL=admin@example.test
# LOG_FORMAT=text
# REDIS_URL=
# PLATFORM_ADMIN_EMAIL=platform@example.local
# PLATFORM_ADMIN_PASSWORD=change-me-platform-admin

# Modulsystem (Docker: /app/modules und /app/plugins)
# MODULES_DIR=/app/modules
# PLUGINS_DIR=/app/plugins
# CORE_VERSION=2.0.0

# Einzige Ausnahme für Anwendungs-Verschlüsselung (Secrets in DB)
# APP_ENCRYPTION_KEY=change-me-32-chars-minimum-secret

VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# Optional: Cloudflare Turnstile für Bot-Schutz auf der Bestellseite
# VITE_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

