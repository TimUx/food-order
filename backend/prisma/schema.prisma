generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  STAFF
}

enum OrderSource {
  ONLINE
  CASHIER
}

enum StatusCode {
  NEW
  IN_PROGRESS
  READY
  PICKED_UP
  CANCELLED
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantApplicationStatus {
  NEW
  UNDER_REVIEW
  CLARIFICATION
  APPROVED
  REJECTED
  ARCHIVED
}

enum AuthTokenType {
  MAGIC_LINK
  LOGIN_CODE
  PASSWORD_RESET
}

/// Plattformadministrator – gehört keinem Mandanten
model PlatformUser {
  id                String                    @id @default(uuid())
  username          String?                   @unique
  email             String                    @unique
  passwordHash      String?                   @map("password_hash")
  passwordEnabled   Boolean                   @default(false) @map("password_enabled")
  magicLinkEnabled  Boolean                   @default(true) @map("magic_link_enabled")
  firstName         String                    @map("first_name")
  lastName          String                    @map("last_name")
  active            Boolean                   @default(true)
  permissions       Json                      @default("[]")
  mfaEnabled        Boolean                   @default(false) @map("mfa_enabled")
  lastLoginAt       DateTime?                 @map("last_login_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  sessions          PlatformUserSession[]
  loginTokens       PlatformAuthLoginToken[]

  @@map("platform_users")
}

model PlatformAuthLoginToken {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  user      PlatformUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String        @unique @map("token_hash")
  type      AuthTokenType
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  ipAddress String?       @map("ip_address")
  userAgent String?       @map("user_agent")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([userId])
  @@map("platform_auth_login_tokens")
}

model PlatformUserSession {
  id               String       @id @default(uuid())
  userId           String       @map("user_id")
  user             PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String       @unique @map("refresh_token_hash")
  expiresAt        DateTime     @map("expires_at")
  revokedAt        DateTime?    @map("revoked_at")
  userAgent        String?      @map("user_agent")
  createdAt        DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@map("platform_user_sessions")
}

model Tenant {
  id            String       @id @default(uuid())
  name          String
  shortName     String?      @map("short_name")
  slug          String       @unique
  subdomain     String       @unique
  status        TenantStatus @default(ACTIVE)
  contactName   String?      @map("contact_name")
  email         String?
  phone         String?
  logoUrl       String?      @map("logo_url")
  locale        String       @default("de-DE")
  timezone      String       @default("Europe/Berlin")
  currency      String       @default("EUR")
  theme         String       @default("default")
  description   String?
  address       String?
  website       String?
  activatedAt   DateTime?    @map("activated_at")
  archivedAt    DateTime?    @map("archived_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  settings      TenantSettings?
  users         User[]
  events        Event[]
  customers     Customer[]
  foodItems     FoodItem[]
  eventFoodItems EventFoodItem[]
  orders        Order[]
  dailyCounters DailyOrderCounter[]
  legalPages    LegalPage[]
  modules       TenantModule[]
  clubSettings  ClubSettings[]
  loginTokens   AuthLoginToken[]

  @@index([status])
  @@index([subdomain])
  @@index([slug])
  @@map("tenants")
}

model TenantSettings {
  tenantId                    String   @id @map("tenant_id")
  tenant                      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderFieldFirstNameRequired Boolean  @default(true) @map("order_field_first_name_required")
  orderFieldLastNameRequired  Boolean  @default(true) @map("order_field_last_name_required")
  orderFieldEmailRequired     Boolean  @default(false) @map("order_field_email_required")
  orderFieldPhoneRequired     Boolean  @default(false) @map("order_field_phone_required")
  cancellationDeadlineHours   Int      @default(24) @map("cancellation_deadline_hours")
  cancellationDeadlineUnit    String   @default("hours") @map("cancellation_deadline_unit")
  dataRetentionDays           Int      @default(365) @map("data_retention_days")
  extraJson                   Json     @default("{}") @map("extra_json")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

model PlatformSettings {
  key       String   @id
  value     Json
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("platform_settings")
}

/// Plattformweite Rollendefinitionen (ADMIN, STAFF) – nicht mandantenspezifisch
model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())
  users       User[]
}

model User {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  username          String?
  email             String?
  passwordHash      String?          @map("password_hash")
  passwordEnabled   Boolean          @default(false) @map("password_enabled")
  magicLinkEnabled  Boolean          @default(true) @map("magic_link_enabled")
  /// Admin erhält E-Mail-Benachrichtigungen (Bestellungen, Stornierungen, …) für diesen Mandanten
  notificationEmailsEnabled Boolean  @default(false) @map("notification_emails_enabled")
  firstName         String
  lastName          String
  active            Boolean          @default(true)
  roleId            String
  role              Role             @relation(fields: [roleId], references: [id])
  /// Per-user permission keys (role templates). Falls back to Role.permissions when empty.
  permissions       Json             @default("[]")
  /// Applied role template id, e.g. kueche, kasse (legacy display)
  roleTemplate      String?          @map("role_template")
  /// Selected role template ids, e.g. ["kasse","abholung"]
  roleTemplates     Json             @default("[]") @map("role_templates")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  sessions          UserSession[]
  loginTokens       AuthLoginToken[]

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, username])
}

model AuthLoginToken {
  id        String        @id @default(uuid())
  tenantId  String        @map("tenant_id")
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String        @unique @map("token_hash")
  type      AuthTokenType
  codeHash  String?       @map("code_hash")
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  ipAddress String?       @map("ip_address")
  userAgent String?       @map("user_agent")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@index([expiresAt])
  @@map("auth_login_tokens")
}

model UserSession {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  userAgent        String?
  createdAt        DateTime  @default(now())

  @@index([userId])
}

model Event {
  id                  String     @id @default(uuid())
  tenantId            String     @map("tenant_id")
  tenant              Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  date                DateTime   @db.Date
  startTime           String
  endTime             String
  onlineOrdersActive  Boolean    @default(true)
  cashierActive       Boolean    @default(true)
  ordersClosed        Boolean    @default(false)
  isActive            Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  foodItems           EventFoodItem[]
  orders              Order[]
  dailyCounters       DailyOrderCounter[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, createdAt])
}

model DailyOrderCounter {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  counter   Int      @default(0)

  @@unique([eventId, date])
  @@index([tenantId])
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  orders    Order[]

  @@index([tenantId])
}

model FoodItem {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal          @db.Decimal(10, 2)
  imageUrl    String?
  sortOrder   Int              @default(0)
  active      Boolean          @default(true)
  maxQuantity Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]
  eventLinks  EventFoodItem[]

  @@index([tenantId])
}

model EventFoodItem {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventId    String   @map("event_id")
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  foodItemId String   @map("food_item_id")
  foodItem   FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0) @map("sort_order")
  soldOut    Boolean  @default(false) @map("sold_out")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([eventId, foodItemId])
  @@index([tenantId])
  @@index([eventId])
  @@index([foodItemId])
  @@map("event_food_items")
}

model Order {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id])
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  lookupToken     String        @unique
  orderNumber     Int
  orderDate       DateTime      @db.Date
  source          OrderSource
  status          StatusCode    @default(NEW)
  releasedToKitchen Boolean     @default(false) @map("released_to_kitchen")
  totalPrice      Decimal       @db.Decimal(10, 2)
  readyAt         DateTime?
  pickedUpAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           OrderItem[]
  statusHistory   OrderStatus[]

  @@unique([eventId, orderDate, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, eventId])
  @@index([tenantId, createdAt])
  @@index([eventId, status])
  @@index([tenantId, eventId, status])
  @@index([tenantId, updatedAt])
  @@index([eventId, status, readyAt])
  @@index([tenantId, lookupToken])
  @@index([tenantId, eventId, releasedToKitchen])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodItemId String
  foodItem   FoodItem @relation(fields: [foodItemId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  lineTotal  Decimal  @db.Decimal(10, 2)

  @@index([orderId])
}

model OrderStatus {
  id        String     @id @default(uuid())
  orderId   String
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    StatusCode
  changedBy String?
  createdAt DateTime   @default(now())

  @@index([orderId])
}

/// Legacy – wird schrittweise durch TenantSettings ersetzt
model ClubSettings {
  id                          String   @id @default("default")
  tenantId                    String?  @unique @map("tenant_id")
  tenant                      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clubName                    String   @default("FestSchmiede")
  description                 String?
  contactName                 String?
  email                       String?
  phone                       String?
  address                     String?
  website                     String?
  logoUrl                     String?
  orderFieldFirstNameRequired Boolean  @default(true)
  orderFieldLastNameRequired  Boolean  @default(true)
  orderFieldEmailRequired     Boolean  @default(false)
  orderFieldPhoneRequired     Boolean  @default(false)
  cancellationDeadlineHours   Int      @default(24)
  cancellationDeadlineUnit    String   @default("hours")
  dataRetentionDays           Int      @default(365)
  smtpHost                    String?
  smtpPort                    Int      @default(587)
  smtpUser                    String?
  smtpPass                    String?
  smtpFrom                    String?
  emailCustomText             String?
  updatedAt                   DateTime @updatedAt
}

model LegalPage {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pageType    String   @map("page_type")
  title       String
  slug        String
  enabled     Boolean  @default(false)
  published   Boolean  @default(false)
  contentHtml String   @default("") @map("content_html")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([tenantId, pageType])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("legal_pages")
}

/// Mandantenscharfe Modulverwaltung
model TenantModule {
  tenantId         String    @map("tenant_id")
  moduleId         String    @map("module_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleVersion    String    @default("0.0.0") @map("module_version")
  installed        Boolean   @default(false)
  /// Vom Plattform-Admin freigegeben – Mandant darf Modul installieren/aktivieren
  available        Boolean   @default(false)
  enabled          Boolean   @default(false)
  installedAt      DateTime? @map("installed_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  configJson       Json      @default("{}") @map("config_json")
  lastHealthStatus String?   @map("last_health_status")
  lastHealthCheck  DateTime? @map("last_health_check")
  everInstalled    Boolean   @default(false) @map("ever_installed")
  everActivated    Boolean   @default(false) @map("ever_activated")
  lifecycleStatus  String?   @map("lifecycle_status")
  lastError        String?   @map("last_error")
  schemaVersion    String    @default("0") @map("schema_version")
  imageVersion     String?   @map("image_version")

  migrations ModuleMigration[]

  @@id([tenantId, moduleId])
  @@index([tenantId])
  @@map("modules")
}

/// Ausgeführte Modul-Migrationen pro Mandant
model ModuleMigration {
  tenantId   String       @map("tenant_id")
  moduleId   String       @map("module_id")
  migration  String
  appliedAt  DateTime     @default(now()) @map("applied_at")
  module     TenantModule @relation(fields: [tenantId, moduleId], references: [tenantId, moduleId], onDelete: Cascade)

  @@id([tenantId, moduleId, migration])
  @@index([tenantId])
  @@map("module_migrations")
}

/// Plattform-Audit-Log – tenant_id optional für mandantenbezogene Aktionen
model PlatformAuditLog {
  id        String   @id @default(cuid())
  action    String
  actorId   String?  @map("actor_id")
  tenantId  String?  @map("tenant_id")
  moduleId  String?  @map("module_id")
  details   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([moduleId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@map("platform_audit_log")
}

/// Mandantenbewerbung über die öffentliche Homepage (Plattformebene)
model TenantApplication {
  id                    String                  @id @default(uuid())
  organization          String
  organizationType      String                  @map("organization_type")
  contactName           String                  @map("contact_name")
  street                String
  postalCode            String                  @map("postal_code")
  city                  String
  country               String                  @default("Deutschland")
  email                 String
  phone                 String?
  website               String?
  memberCount           Int?                    @map("member_count")
  eventsPerYear         Int?                    @map("events_per_year")
  reason                String
  desiredFeatures       String                  @map("desired_features")
  freeTierJustification String                  @map("free_tier_justification")
  plannedUsage          String                  @map("planned_usage")
  notes                 String?
  requestedSubdomain    String                  @map("requested_subdomain")
  status                TenantApplicationStatus @default(NEW)
  adminComment          String?                 @map("admin_comment")
  reviewedBy            String?                 @map("reviewed_by")
  reviewedAt            DateTime?               @map("reviewed_at")
  tenantId              String?                 @map("tenant_id")
  privacyAccepted       Boolean                 @default(true) @map("privacy_accepted")
  termsAccepted         Boolean                 @default(true) @map("terms_accepted")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  @@unique([requestedSubdomain])
  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("tenant_applications")
}

/// Rechtliche Seiten auf Plattformebene (www / apex)
model PlatformLegalPage {
  id          String   @id @default(uuid())
  pageType    String   @map("page_type")
  title       String
  slug        String   @unique
  enabled     Boolean  @default(true)
  published   Boolean  @default(false)
  contentHtml String   @map("content_html") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([pageType])
  @@map("platform_legal_pages")
}
