  },
  "permissions": [
    { "key": "legal.view", "description": "Rechtliche Informationen einsehen" },
    { "key": "legal.manage", "description": "Rechtliche Informationen bearbeiten" },
    { "key": "legal.publish", "description": "Rechtliche Informationen veroeffentlichen" }
  ],
  "menus": [
    {
      "id": "legal-admin",
      "label": "Rechtliche Informationen",
      "path": "/admin/legal",
      "icon": "Gavel",
      "parentId": "modules",
      "sortOrder": 30,
      "requiredPermission": "legal.view"
    }
  ],
  "reports": [
    {
      "id": "legal-admin",
      "label": "Rechtliche Informationen",
      "description": "Uebersicht, Seiten, Einstellungen und Vorschau",
      "path": "/admin/legal",
      "icon": "Gavel",
      "componentId": "legal.admin",
      "sortOrder": 30,
      "requiredPermission": "legal.view"
    }
  ],
  "settings": {
    "namespace": "module.legal",
    "label": "Rechtliche Informationen",
    "description": "Footer-Links und Impressum-Ergaenzungen",
    "adminPath": "/admin/legal",
    "permission": "legal.manage",
    "groups": [
      { "id": "general", "label": "Allgemein" }
    ],
    "fields": [
      {
        "key": "appendClubContactToImprint",
        "group": "general",
        "label": "Kontaktinformationen automatisch im Impressum ergaenzen",
        "type": "boolean",
        "default": true
      },
      {
        "key": "showFooterLinks",
        "group": "general",
        "label": "Veroeffentlichte Seiten im Footer der Bestellseite anzeigen",
        "type": "boolean",
        "default": true
      },
      {
        "key": "showNotificationLinks",
        "group": "general",
        "label": "Veroeffentlichte Seiten in Benachrichtigungs-E-Mails verlinken",
        "type": "boolean",
        "default": true
      }
    ]
  },
  "healthChecks": [
    {
      "id": "pages",
      "label": "Rechtliche Seiten",
      "description": "Verfuegbarkeit veroeffentlichter Seiten"
    }
  ],
  "minimumCoreVersion": "1.0.0",
  "productionReady": true,
  "qa": {
    "participatesInScenarios": false,
    "providesSeed": false
